/static/181563f2b9932b0b020cf28fce3f8afc/403a4/irs-ftb-cdtfa-representation.webp 300w,\n/static/181563f2b9932b0b020cf28fce3f8afc/1f5c5/irs-ftb-cdtfa-representation.webp 400w,\n/static/181563f2b9932b0b020cf28fce3f8afc/a3e81/irs-ftb-cdtfa-representation.webp 512w","sizes":"(max-width: 200px) 100vw, 200px"}}}}]},"ServiceIllustrationImage":{"childImageSharp":{"fluid":{"base64":"data:image/png;base64,","aspectRatio":1.7328519855595668,"src":"/static/9be0a06732e0b408425a56f967d55afa/b41c1/service-illustration.png","srcSet":"/static/9be0a06732e0b408425a56f967d55afa/19ca5/service-illustration.png 480w,\n/static/9be0a06732e0b408425a56f967d55afa/b41c1/service-illustration.png 784w","srcWebp":"/static/9be0a06732e0b408425a56f967d55afa/7c4c6/service-illustration.webp","srcSetWebp":"/static/9be0a06732e0b408425a56f967d55afa/61be4/service-illustration.webp 480w,\n/static/9be0a06732e0b408425a56f967d55afa/7c4c6/service-illustration.webp 784w","sizes":"(max-width: 784px) 100vw, 784px"}}}}}